generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id             String               @id @default(cuid())
  name           String
  industry       String?
  reportingYear  Int?
  createdAt      DateTime             @default(now())
  users          User[]
  facilities     Facility[]
  emissionRecords EmissionRecord[]
  suppliers      Supplier[]
  submissions    SupplierSubmission[]
  issues         Issue[]
  scenarios      Scenario[]
  reports        Report[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String       @unique
  role           String       // SUSTAINABILITY_MANAGER, OPERATIONS_ADMIN, SUPPLIER, LEADERSHIP_REVIEWER
  createdAt      DateTime     @default(now())
}

model Facility {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  name           String
  location       String?
  type           String?
  createdAt      DateTime         @default(now())
  records        EmissionRecord[]
}

model EmissionRecord {
  id                  String         @id @default(cuid())
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id])
  facilityId          String
  facility            Facility       @relation(fields: [facilityId], references: [id])
  sourceType          String
  scope               String
  category            String
  activityValue       Float
  activityUnit        String
  emissionFactorId    String?
  emissionFactor      EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  calculatedEmissions Float?
  periodMonth         Int
  periodYear          Int
  status              String         // ACCEPTED, FLAGGED, etc.
  createdAt           DateTime       @default(now())
}

model EmissionFactor {
  id              String           @id @default(cuid())
  name            String
  scope           String
  category        String
  factorValue     Float
  factorUnit      String
  sourceReference String?
  createdAt       DateTime         @default(now())
  records         EmissionRecord[]
}

model Supplier {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  name           String
  contactName    String?
  contactEmail   String?
  category       String?
  priorityTier   String?
  createdAt      DateTime             @default(now())
  submissions    SupplierSubmission[]
}

model SupplierSubmission {
  id               String       @id @default(cuid())
  supplierId       String
  supplier         Supplier     @relation(fields: [supplierId], references: [id])
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  scope3Category   String
  activityValue    Float
  activityUnit     String
  reportingPeriod  String
  dataQualityScore Int?
  status           String       // SUBMITTED, VALIDATED, REJECTED
  notes            String?
  createdAt        DateTime     @default(now())
}

model Issue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  recordType     String       // EMISSION_RECORD or SUPPLIER_SUBMISSION
  recordId       String
  title          String
  description    String?
  severity       String?
  status         String       // OPEN, RESOLVED
  ownerUserId    String?
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
}

model Scenario {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String
  assumptionType  String
  assumptionValue Float
  estimatedImpact Float
  createdAt       DateTime     @default(now())
}

model Report {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  title             String
  reportingPeriod   String
  summary           String?
  generatedByUserId String?
  createdAt         DateTime     @default(now())
}
